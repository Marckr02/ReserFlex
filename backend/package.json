{
  "name": "reservflex-backend",
  "version": "1.0.0",
  "description": "Backend API para ReserFlex",
  "main": "src/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "postinstall": "prisma generate",
    "seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force && npm run seed",
    "sonar:cloud": "sonar-scanner -Dsonar.token=%SONAR_TOKEN% -Dsonar.organization=%SONAR_ORG%"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.15",
    "pdfkit": "^0.19.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "prisma": "^7.8.0"
  }
}
